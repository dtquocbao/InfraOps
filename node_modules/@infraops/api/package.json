{
  "name": "@infraops/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "npx nest build",
    "dev": "npx nest start --watch",
    "start": "node dist/src/main.js",
    "start:prod": "node dist/src/main.js",
    "lint": "echo \"No lint configured for api\"",
    "typecheck": "tsc --noEmit",
    "test": "jest --passWithNoTests",
    "db:generate": "npx prisma generate",
    "db:migrate": "npx prisma migrate deploy",
    "db:migrate:dev": "npx prisma migrate dev",
    "db:seed": "node dist/prisma/seed.js",
    "db:seed:dev": "ts-node --project tsconfig.json prisma/seed.ts"
  },
  "dependencies": {
    "@infraops/ai-tools": "*",
    "@infraops/shared": "*",
    "@nestjs/common": "^11.0.12",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.12",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.12",
    "@nestjs/swagger": "^11.1.0",
    "@prisma/client": "^6.5.0",
    "bcryptjs": "^3.0.2",
    "bullmq": "^5.44.4",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "ioredis": "^5.6.0",
    "nestjs-pino": "^4.4.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "uuid": "^11.1.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.6",
    "@nestjs/schematics": "^11.0.5",
    "@nestjs/testing": "^11.0.12",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^5.0.1",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.13.11",
    "@types/passport-jwt": "^4.0.1",
    "@types/uuid": "^10.0.0",
    "jest": "^29.7.0",
    "prisma": "^6.5.0",
    "ts-jest": "^29.2.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.2"
  },
  "prisma": {
    "seed": "node dist/prisma/seed.js"
  }
}
