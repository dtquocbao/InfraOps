generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

enum UserRole {
  engineer
  pm
  safety
  executive
  admin
}

enum ReviewStatus {
  draft
  pending_review
  approved
  rejected
  published
}

enum AgentType {
  rag
  contract
  project
  iot
}

enum FeatureTestCaseStatus {
  passed
  failed
  skipped
  error
}

enum FeatureTestRunStatus {
  running
  completed
  failed
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      UserRole @default(engineer)
  createdAt DateTime @default(now()) @map("created_at")

  agentRuns       AgentRun[]
  reviews         Review[]         @relation("Reviewer")
  auditLogs       AuditLog[]
  featureTestRuns FeatureTestRun[] @relation("FeatureTestTriggeredBy")

  @@map("users")
}

model Project {
  id         String   @id @default(cuid())
  name       String
  discipline String
  status     String   @default("active")
  createdAt  DateTime @default(now()) @map("created_at")

  documents  Document[]
  iotDevices IotDevice[]

  @@map("projects")
}

model Document {
  id               String   @id @default(cuid())
  projectId        String?  @map("project_id")
  title            String
  docType          String   @map("doc_type")
  revision         String   @default("1.0")
  approvalStatus   String   @map("approval_status")
  department       String
  securityLevel    String   @map("security_level")
  storageUri       String   @map("storage_uri")
  processingStatus String   @default("pending") @map("processing_status")
  createdAt        DateTime @default(now()) @map("created_at")

  project Project?        @relation(fields: [projectId], references: [id])
  chunks  DocumentChunk[]

  @@map("documents")
}

model DocumentChunk {
  id         String                       @id @default(cuid())
  documentId String                       @map("document_id")
  content    String
  embedding  Unsupported("vector(1536)")?
  metadata   Json                         @default("{}")
  chunkIndex Int                          @map("chunk_index")

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@map("document_chunks")
}

model AgentRun {
  id         String    @id @default(cuid())
  userId     String    @map("user_id")
  agentType  AgentType @map("agent_type")
  input      Json
  output     Json?
  toolCalls  Json      @default("[]") @map("tool_calls")
  citations  Json      @default("[]")
  traceId    String    @map("trace_id")
  latencyMs  Int?      @map("latency_ms")
  tokenCount Int?      @map("token_count")
  costUsd    Float?    @map("cost_usd")
  createdAt  DateTime  @default(now()) @map("created_at")

  user        User         @relation(fields: [userId], references: [id])
  reviews     Review[]
  evaluations Evaluation[]

  @@map("agent_runs")
}

model Review {
  id         String       @id @default(cuid())
  agentRunId String       @map("agent_run_id")
  reviewerId String?      @map("reviewer_id")
  status     ReviewStatus @default(draft)
  comments   String?
  decidedAt  DateTime?    @map("decided_at")

  agentRun AgentRun @relation(fields: [agentRunId], references: [id])
  reviewer User?    @relation("Reviewer", fields: [reviewerId], references: [id])

  @@map("reviews")
}

model IotDevice {
  id         String  @id @default(cuid())
  projectId  String? @map("project_id")
  deviceType String  @map("device_type")
  name       String
  location   String

  project Project?   @relation(fields: [projectId], references: [id])
  events  IotEvent[]

  @@map("iot_devices")
}

model IotEvent {
  id             String   @id @default(cuid())
  deviceId       String   @map("device_id")
  reading        Json
  anomalyScore   Float?   @map("anomaly_score")
  scoringBackend String   @default("heuristic") @map("scoring_backend")
  modelVersion   String?  @map("model_version")
  explanation    String?
  createdAt      DateTime @default(now()) @map("created_at")

  device IotDevice @relation(fields: [deviceId], references: [id])

  @@map("iot_events")
}

model Evaluation {
  id                String   @id @default(cuid())
  agentRunId        String   @map("agent_run_id")
  groundedness      Float?
  citationAccuracy  Float?   @map("citation_accuracy")
  hallucinationFlag Boolean  @default(false) @map("hallucination_flag")
  relevance         Float?
  userRating        Int?     @map("user_rating")
  mlflowRunId       String?  @map("mlflow_run_id")
  evalBackend       String   @default("heuristic") @map("eval_backend")
  judgeScores       Json?    @map("judge_scores")
  evaluatedAt       DateTime @default(now()) @map("evaluated_at")

  agentRun AgentRun @relation(fields: [agentRunId], references: [id])

  @@map("evaluations")
}

model AuditLog {
  id           String   @id @default(cuid())
  userId       String?  @map("user_id")
  action       String
  resourceType String   @map("resource_type")
  resourceId   String?  @map("resource_id")
  metadata     Json     @default("{}")
  createdAt    DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id])

  @@map("audit_log")
}

model SystemSetting {
  key       String   @id
  value     String   @default("")
  updatedAt DateTime @updatedAt @map("updated_at")
  updatedBy String?  @map("updated_by")

  @@map("system_settings")
}

model FeatureTestRun {
  id               String               @id @default(cuid())
  triggeredById    String?              @map("triggered_by_id")
  source           String               @default("admin")
  status           FeatureTestRunStatus @default(running)
  passCount        Int                  @default(0) @map("pass_count")
  failCount        Int                  @default(0) @map("fail_count")
  skipCount        Int                  @default(0) @map("skip_count")
  totalCount       Int                  @default(0) @map("total_count")
  retrievalBackend String?              @map("retrieval_backend")
  summary          Json                 @default("{}")
  startedAt        DateTime             @default(now()) @map("started_at")
  completedAt      DateTime?            @map("completed_at")

  triggeredBy User?               @relation("FeatureTestTriggeredBy", fields: [triggeredById], references: [id])
  results     FeatureTestResult[]

  @@map("feature_test_runs")
}

model FeatureTestResult {
  id         String                @id @default(cuid())
  runId      String                @map("run_id")
  testCaseId String                @map("test_case_id")
  category   String
  name       String
  status     FeatureTestCaseStatus
  message    String?
  durationMs Int?                  @map("duration_ms")
  details    Json                  @default("{}")

  run FeatureTestRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId])
  @@index([testCaseId])
  @@map("feature_test_results")
}
